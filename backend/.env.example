# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_recruitment

# Redis (async task queue)
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI (OpenAI compatible — 支持 OpenAI / 通义千问 / 智谱GLM)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=2000
AI_TIMEOUT_SECONDS=60

# AI 评分阈值
AI_MIN_SCORE_FOR_RECOMMEND=60
AI_COST_CAP_PER_MONTH=0.0

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# App
APP_NAME=AI Recruitment System
DEBUG=True
